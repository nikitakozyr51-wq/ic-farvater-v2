# Don't ship dev files into the Docker image — keeps image lean

# Git
.git
.gitignore
.gitattributes

# Build artefacts
dist/
node_modules/

# Dev tools / Claude / Pencil / audit
.claude/
.agents/
.lazyweb/
.playwright-mcp/
.youtube-analyze/
.mcp.json
.vscode/
.idea/

# Dev scripts (only PHP ships — send.php; build/sync helpers не нужны в image)
scripts/*.py
scripts/*.ps1
scripts/*.mjs
scripts/*.js

# CI / GitHub Actions — не нужно в Docker-образе
.github/
.token

# Photo archive sources — в git (бэкап), но не в Docker-образ
_upload-photos/
_photo-review/

# Audit artefacts
screenshots/
docs/
*.json
!assets/favicon/site.webmanifest
!**/manifest.json
!composer.json
!composer.lock

# Vendor — устанавливается Composer внутри Docker
vendor/

# Markdown docs (защищено также .htaccess — но не нужно вообще в image)
*.md

# OS junk
.DS_Store
Thumbs.db
*.log

# Editor backups
*~
*.bak
*.pen.bak
