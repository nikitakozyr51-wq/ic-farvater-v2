# IC Фарватер — Apache конфиг для Beget
# Размещается в корне сайта.

# ===========================================================
# PHP upload limits (для KP-формы: до 5 файлов, 10 MB суммарно)
# ===========================================================
php_value upload_max_filesize 10M
php_value post_max_size 12M
php_value max_file_uploads 5
php_value memory_limit 64M

# ===========================================================
# Default charset
# ===========================================================
AddDefaultCharset UTF-8

# ===========================================================
# GZIP compression (для текстовых ресурсов)
# ===========================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/ld+json application/xml application/xml+rss image/svg+xml font/woff2 font/woff
</IfModule>

# ===========================================================
# Cache headers
# Static assets — 1 year (fingerprinted via ?v= cache-bust)
# HTML — no-cache (всегда свежий)
# ===========================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                 "access plus 0 seconds"
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType font/woff                 "access plus 1 year"
  ExpiresByType application/manifest+json "access plus 1 week"
</IfModule>

<IfModule mod_headers.c>
  # HTML — всегда свежий
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # Static — long-term cache
  <FilesMatch "\.(css|js|jpg|jpeg|png|svg|webp|ico|woff2|woff)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# ===========================================================
# Security headers
# ===========================================================
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # HSTS — включить ПОСЛЕ установки SSL на Beget
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ===========================================================
# Защита служебных файлов
# ===========================================================
<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>
<Files ".htaccess">
  Order allow,deny
  Deny from all
</Files>
<Files "*.md">
  Order allow,deny
  Deny from all
</Files>
<FilesMatch "\.(py|sh|log|sql|json)$">
  Order allow,deny
  Deny from all
</FilesMatch>
# Исключение для site.webmanifest (это .webmanifest, не .json — но на всякий)
<Files "site.webmanifest">
  Order allow,deny
  Allow from all
</Files>

# ===========================================================
# Pretty MIME types
# ===========================================================
AddType image/svg+xml svg
AddType application/manifest+json webmanifest
AddType application/json json
AddType font/woff2 woff2
AddType text/markdown md

# ===========================================================
# Redirect www → non-www (опционально, раскомментировать)
# ===========================================================
# <IfModule mod_rewrite.c>
#   RewriteEngine On
#   RewriteCond %{HTTP_HOST} ^www\.ic-farvater\.ru [NC]
#   RewriteRule ^(.*)$ https://ic-farvater.ru/$1 [L,R=301]
# </IfModule>

